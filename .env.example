# Environment for *Confirmation Bias in LLM Pricing Recommendations*.
# Copy to `.env` (never commit the real file) and fill in values.

# Required for experiment runners (baseline / static / iterative).
OPENROUTER_API_KEY=

# Optional OpenRouter attribution headers.
SITE_URL=
SITE_NAME=Confirmation Bias in LLM Pricing Recommendations

# Optional API tuning.
MAX_RETRIES=4
REQUEST_TIMEOUT_S=180

# Optional: override the system prompt (leave unset to use the design-doc default).
# SYSTEM_PROMPT=
